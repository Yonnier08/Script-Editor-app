<?xml version="1.0" encoding="UTF-8" ?>
<TabbedPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:local="clr-namespace:ScriptEditorMaui"
            x:Class="ScriptEditorMaui.MainPage"
            Title="ScriptEditor"
            BarBackgroundColor="#1F1F1F"
            BarTextColor="White">

    <TabbedPage.BindingContext>
        <local:MainViewModel />
    </TabbedPage.BindingContext>

    <!-- PESTAÑA 1: SCRIPT -->
    <ContentPage Title="Script">
        <VerticalStackLayout Padding="10" Spacing="8">

            <!-- MENÚS PRINCIPALES ESTILO PC -->
            <HorizontalStackLayout BackgroundColor="#2D2D2D" Padding="4" Spacing="4">
                <Button Text="File" Command="{Binding MenuFileCommand}" BackgroundColor="Transparent" TextColor="White" />
                <Button Text="Edit" Command="{Binding MenuEditCommand}" BackgroundColor="Transparent" TextColor="White" />
                <Button Text="Export" Command="{Binding MenuExportCommand}" BackgroundColor="Transparent" TextColor="White" />
                <Button Text="Tools" Command="{Binding MenuToolsCommand}" BackgroundColor="Transparent" TextColor="White" />
                <BoxView WidthRequest="1" BackgroundColor="Gray" Margin="5,0" />
                <Label Text="{Binding StatusMessage}" VerticalOptions="Center" TextColor="LightGray" LineBreakMode="TailTruncation" FontSize="12" />
            </HorizontalStackLayout>

            <!-- OPCIONES RÁPIDAS DE CONFIGURACIÓN -->
            <HorizontalStackLayout Spacing="16">
                <HorizontalStackLayout Spacing="4">
                    <CheckBox IsChecked="{Binding IsBigEndian}" />
                    <Label Text="Big Endian" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="4">
                    <CheckBox IsChecked="{Binding ToLower}" />
                    <Label Text="minúsculas" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="4">
                    <CheckBox IsChecked="{Binding ExcludeStageFilters}" />
                    <Label Text="Excluir filtros de stage" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </HorizontalStackLayout>

            <!-- EDITOR CENTRAL -->
            <Editor Text="{Binding EditorText}"
                    HeightRequest="350"
                    FontFamily="Courier"
                    Placeholder="Comandos DSC..." />

            <!-- ACCIONES RÁPIDAS INFERIORES -->
            <ScrollView Orientation="Horizontal">
                <HorizontalStackLayout Spacing="6">
                    <Button Text="Add Target Flying Time" Command="{Binding AddTargetFlyingTimeCommandsCommand}" />
                    <Button Text="F2 → FT" Command="{Binding AutoFormatF2ToFtCommand}" />
                    <Button Text="FT → F2" Command="{Binding AutoFormatFtToF2Command}" />
                    <Button Text="FT → F2 (Vita)" Command="{Binding AutoFormatFtToF2VitaCommand}" />
                    <Button Text="Quitar chart" Command="{Binding RemoveChartCommand}" />
                    <Button Text="Reformat F Targets" Command="{Binding ReformatFTargetsCommand}" />
                    <Button Text="Reformat FT Targets" Command="{Binding ReformatFtTargetsCommand}" />
                    <Button Text="Quitar TIME sin uso" Command="{Binding RemoveUnusedTimeCommandsCommand}" />
                </HorizontalStackLayout>
            </ScrollView>

        </VerticalStackLayout>
    </ContentPage>

    <!-- PESTAÑA 2: PV-DATABASE -->
    <ContentPage Title="PV-Database">
        <VerticalStackLayout Padding="10" BackgroundColor="#0A0A0A">
            <Editor Text="{Binding PvDbText}"
                    FontFamily="Courier"
                    TextColor="White"
                    BackgroundColor="#121212"
                    IsReadOnly="True"
                    HeightRequest="500"
                    Placeholder="# Aquí aparecerá la estructura del pv_db.txt para FT..." />
        </VerticalStackLayout>
    </ContentPage>

    <!-- PESTAÑA 3: FIELD-DATABASE -->
    <ContentPage Title="Field-Database">
        <VerticalStackLayout Padding="10" BackgroundColor="#0A0A0A">
            <Editor Text="{Binding FieldDbText}"
                    FontFamily="Courier"
                    TextColor="White"
                    BackgroundColor="#121212"
                    IsReadOnly="True"
                    HeightRequest="500"
                    Placeholder="# Aquí aparecerá la estructura del field_db.txt para FT..." />
        </VerticalStackLayout>
    </ContentPage>

</TabbedPage>
